# Clé API Anthropic — obligatoire
ANTHROPIC_API_KEY=sk-ant-...

# Modèle (par défaut: claude-opus-4-7)
MOUNS_MODEL=claude-opus-4-7

# Identité de la société (utilisée dans la signature des emails)
SM_OWNER_NAME=Mounir Stili
SM_COMPANY=SM Project
SM_EMAIL=contact@smproject.fr
SM_PHONE=
SM_WEBSITE=
SM_LINKEDIN=

# SMTP (optionnel — laisse vide pour rester en mode "brouillon")
# Si renseigné, Mouns peut envoyer réellement les emails après confirmation.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=

# Répertoire de stockage (par défaut: ./data)
MOUNS_DATA_DIR=./data
